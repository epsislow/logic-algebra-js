diff --git a/library/logTscript/.cursor/plans/boolean_analysis_helpers.plan.md b/library/logTscript/.cursor/plans/boolean_analysis_helpers.plan.md
index 4b974bf..87c4aba 100644
--- a/library/logTscript/.cursor/plans/boolean_analysis_helpers.plan.md
+++ b/library/logTscript/.cursor/plans/boolean_analysis_helpers.plan.md
@@ -148,7 +148,7 @@ lutOf(OR(AND(A, B), NOT(C)), A=01x1x B=x C=000xx)
 | `data {}` | Toate combinațiile | Doar rândurile care trec filtrele |
 | `fillwith` | **Nu se emite** | **Nu se emite** — fără LUT sparse |
 
-**Adrese în `data {}` (cu filtre):** index secvențial `0 … length-1`, afișat binar cu `bitIndexWidth(length)` biți (ex. 32 rânduri → adrese `00000` … `11111`). Spațiul logic complet (11 biți) rămâne doar în comentarii (`#` header + `#` filtre), nu în `length`.
+- **Adrese în `data {}` (cu filtre):** adresa binară completă pe `totalBits` biți (ex. 11 biți pentru `A 5b, B 1b, C 5b`) — valoarea reală a combinației din filtre, nu un index secvențial `0…length-1`.
 
 Exemplu:
 
diff --git a/library/logTscript/v0_3_2/core/boolean-lut.js b/library/logTscript/v0_3_2/core/boolean-lut.js
index 05f6ef0..fe34ac7 100644
--- a/library/logTscript/v0_3_2/core/boolean-lut.js
+++ b/library/logTscript/v0_3_2/core/boolean-lut.js
@@ -255,7 +255,7 @@ function collectFilteredRows(exprAst, columns, widthResolver, filterMap) {
     else if (result.length !== outWidth) {
       throw new Error('lutOf: inconsistent output width');
     }
-    rows.push({ env, output: result });
+    rows.push({ env, output: result, addr });
   }
   return { rows, addrWidth, outWidth };
 }
@@ -426,13 +426,11 @@ function lutOfGenerate(exprAst, widthResolver, filters) {
   }
 
   const length = filterMap ? rows.length : (1 << addrWidth);
-  const addrPad = filterMap ? bitIndexWidth(length) : addrWidth;
+  const addrPad = addrWidth;
 
   inner.push('', `depth: ${outWidth}`, `length: ${length}`, 'data {');
   for (let i = 0; i < rows.length; i++) {
-    const addrStr = filterMap
-      ? i.toString(2).padStart(addrPad, '0')
-      : i.toString(2).padStart(addrPad, '0');
+    const addrStr = rows[i].addr.toString(2).padStart(addrPad, '0');
     inner.push(`  ${addrStr} : ${rows[i].output}`);
   }
   inner.push('}');
diff --git a/library/logTscript/v0_3_2/doc/boolean-lut.md b/library/logTscript/v0_3_2/doc/boolean-lut.md
index 9e109c9..690aeaa 100644
--- a/library/logTscript/v0_3_2/doc/boolean-lut.md
+++ b/library/logTscript/v0_3_2/doc/boolean-lut.md
@@ -43,7 +43,7 @@ Instance name is always **`.generated`**. Paste the block into a script, then us
 ### Rules
 
 - **Row limit:** max **256 rows** in `data { }`. Error: `Boolean analysis exceeds maximum supported table size (256 rows)`.
-- **With filters:** `length` = number of rows emitted (≤ 256); comment line `# A=01x1x B=x` documents filters. No `fillwith` / sparse full address space.
+- **With filters:** `length` = number of rows emitted (≤ 256); comment line `# A=01x1x B=x` documents filters. Addresses in `data { }` use the **full input bit width** (e.g. 11 bits), not a sequential row index.
 - **Without filters:** `length = 2^(sum column widths)` (≤ 256).
 - Undeclared atomic variables (`A`, `B` in gates) default to **1 bit**.
 - Whole wires (`lutOf(C)` on `7wire C`) use the declared wire width.
