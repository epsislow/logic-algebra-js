diff --git a/library/logTscript/v0_3_2/test_suite_ported.js b/library/logTscript/v0_3_2/test_suite_ported.js
index cf90fc1..dc3c8f0 100644
--- a/library/logTscript/v0_3_2/test_suite_ported.js
+++ b/library/logTscript/v0_3_2/test_suite_ported.js
@@ -5684,6 +5684,19 @@ lutOf(OR(AND(A, B), NOT(C)), A=01x1x B=x C=000xx)`);
   h.assert('length', String(out.some(l => l.trim() === 'length: 32')), 'true');
   const dataLines = out.filter(l => /^\s+[01]+ : [01]+$/.test(l));
   h.assert('data count', String(dataLines.length), '32');
+  h.assert('addr width', String(dataLines[0].trim().split(':')[0].trim().length), '11');
+});
+
+reg(1146, 'bool-lut-mb', 'lutOf filtre — adresă 11b nu index secvențial', function(h, session) {
+  const { out } = session.run(`5wire A
+1wire B
+5wire C
+lutOf(OR(AND(A, B), NOT(C)), A=01x1x B=x C=1001x)`);
+  h.assert('length 16', String(out.some(l => l.trim() === 'length: 16')), 'true');
+  const dataLines = out.filter(l => /^\s+[01]+ : [01]+$/.test(l));
+  h.assert('count', String(dataLines.length), '16');
+  h.assert('not sequential 4b', String(!dataLines[0].includes('0000 :')), 'true');
+  h.assert('addr 11b', String(dataLines[0].trim().split(':')[0].trim().length), '11');
 });
 
 reg(1144, 'bool-lut', 'lutOf fără filtre — fără linie filtru', function(h, session) {
