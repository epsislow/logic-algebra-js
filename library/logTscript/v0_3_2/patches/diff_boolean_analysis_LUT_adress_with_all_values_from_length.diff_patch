       { id: 'bool-lut', label: 'bool-lut', rangeLabel: '1091–1107, 1122, 1136, 1143–1144', testIds: [1091, 1092, 1093, 1094, 1095, 1096, 1097, 1098, 1099, 1100, 1101, 1102, 1103, 1104, 1105, 1106, 1107, 1122, 1136, 1143, 1144] },
