+      {"id":1146,"group":"bool-lut-mb","title":"lutOf filtre — adresă 11b nu index secvențial","detail":{"scripts":["5wire A\n1wire B\n5wire C\nlutOf(OR(AND(A, B), NOT(C)), A=01x1x B=x C=1001x)"],"steps":[],"assertions":["length 16","count","not sequential 4b","addr 11b"]}}
